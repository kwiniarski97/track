# Drizzle
DATABASE_URL=local.db

# SvelteKit adapter-node (must be the public HTTPS origin in production)
ORIGIN=http://localhost:3000
# Default is 512K, too small for a TV Time export zip upload
BODY_SIZE_LIMIT=20M

# Session cookies
SESSION_SECRET=

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Pocket ID (OIDC) - create a client in your Pocket ID instance
POCKET_ID_ISSUER=
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=

# Jellyfin
JELLYFIN_URL=
JELLYFIN_API_KEY=
